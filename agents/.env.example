# Copy to agents/.env and fill in. Loaded automatically (python-dotenv).

# --- App endpoints ---
# Convex httpActions base (review / clauses / flag / approve).
CONVEX_SITE_URL=https://neighborly-lynx-882.convex.site
# Next.js app base (vector similarity route). The app must be running.
APP_BASE_URL=http://localhost:3000

# --- Crew M2M identity (mints its own Kinde token) ---
KINDE_DOMAIN=devrelstudio.kinde.com
CREW_M2M_CLIENT_ID=ea086951677f4d24a6bdefe409d62448
CREW_M2M_CLIENT_SECRET=
KINDE_AUDIENCE=contract-intelligence-api

# --- LLM (crew mode) ---
# LiteLLM model id; defaults to Claude. Set the matching provider key below.
CREW_LLM_MODEL=anthropic/claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=   # if you set CREW_LLM_MODEL to an OpenAI model instead
