# Copy to .env.local and fill in. Never commit real secrets.

# --- Kinde tenant (agent-auth component / token verification) ---
# Your Kinde tenant host WITHOUT protocol, e.g. your-org.kinde.com — issuer of
# the agent M2M tokens the component verifies. (KINDE_ISSUER_URL below is the
# same host WITH https://.)
KINDE_DOMAIN=
# API audience the agent tokens are minted for; required in live mode so a token
# minted for another API in the same tenant cannot be replayed here.
KINDE_AUDIENCE=

# --- Kinde Next.js web app (human sign-in via @kinde-oss/kinde-auth-nextjs) ---
# Web-app (regular) client credentials from the Kinde application.
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
# Kinde issuer URL for the web app, e.g. https://your-org.kinde.com
KINDE_ISSUER_URL=
# Base URL of this app, e.g. http://localhost:3000
KINDE_SITE_URL=http://localhost:3000
# Where Kinde redirects after login / logout.
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# --- Delegation signing ---
# HMAC secret used to sign scope delegations. Must be 32+ chars of high entropy.
DELEGATION_SIGNING_SECRET=

# --- Crew agent M2M application (the AI crew's own Kinde identity) ---
# Machine-to-machine client credentials the agent crew authenticates with.
CREW_M2M_CLIENT_ID=
CREW_M2M_CLIENT_SECRET=

# --- Kinde Management API M2M (resolve a human's org permissions server-side) ---
# A separate M2M application authorized for the Kinde Management API, used to
# resolve a human's permission ceiling from Kinde: at review-start (Convex
# deployment env) AND for guest-mode role resolution (this app's env). Set it in
# both places. See docs/kinde-setup.md.
KINDE_MGMT_CLIENT_ID=
KINDE_MGMT_CLIENT_SECRET=

# --- Guest demo mode ("view as Intern/Analyst/Admin") ---
# The switcher maps a role to a PRE-PROVISIONED Kinde test user and mints a real
# guest session for that user server-side (UX convenience over real auth, not a
# bypass — the acting subject is a real Kinde id, so authorize()/Management-API
# resolution runs genuinely). These are Kinde user ids + an org code (CONFIG, not
# secrets); the test users' credentials are never involved and never reach the
# client. Guest resolution also needs KINDE_MGMT_* above (app-side this time).
DEMO_ORG_CODE=
DEMO_INTERN_SUBJECT=
DEMO_ANALYST_SUBJECT=
DEMO_ADMIN_SUBJECT=

# --- Weaviate (vector store for contract retrieval) ---
# Local Docker: http://localhost:8080 (no API key). Weaviate Cloud: the cluster
# REST endpoint URL + its admin API key. See docs/weaviate-setup.md.
WEAVIATE_URL=
WEAVIATE_API_KEY=

# --- LLM for the CrewAI service (agents/) ---
# BYOK is the product path: the visitor supplies their own key per run (never
# stored/logged/in-env). This optional server key is a LOCAL-DEV fallback so runs
# work without BYOK; leave it blank to require BYOK. See docs/agent-service.md.
ANTHROPIC_API_KEY=

# --- BYOK crew run service (agents/ contract_crew.service:app) ---
# OPTIONAL — only for the "Crew (LLM · BYOK)" run mode. The "Deterministic" run
# mode is self-contained (the Next.js /api/run route drives Convex directly) and
# needs nothing here. Leave BLANK unless you're running the LLM crew service; the
# route only forwards the visitor's key (used once, never persisted) when set.
# Start the service with (from agents/, `pip install -e .[service]`):
#   uvicorn contract_crew.service:app --port 8790
# Pick a free port and match it here, e.g. CREW_SERVICE_URL=http://localhost:8790
CREW_SERVICE_URL=

# --- Demo authorization mode (SERVER-decided; set on the Convex deployment) ---
# Set with `npx convex env set AUTHZ_MODE broken|intersection` — NOT chosen by
# the calling agent. Default is `broken`.
# broken       = the confused-deputy bug: agent actions authorized on the agent's
#                identity alone; the acting human's permissions are never checked.
# intersection = the fix: agent capabilities ∩ the acting human's permissions,
#                enforced by the component's authorize() (denies with a
#                machine-readable reason + correlationId + audit row).
AUTHZ_MODE=broken

# --- Demo mode selection (SERVER-decided; set on the Convex deployment) ---
# Set with `npx convex env set DEMO_MODE_SELECTABLE true`. When on, the demo
# OPERATOR may pick the mode per run (so a visitor can watch the problem AND the
# fix without a redeploy). OFF by default and in real deployments — there the
# mode is AUTHZ_MODE alone and a calling agent can never choose how strictly it
# is checked. This is a demo escape hatch, not a production control.
DEMO_MODE_SELECTABLE=false

# --- Convex ---
# Public deployment URL for the browser client; set by `convex dev`.
NEXT_PUBLIC_CONVEX_URL=
