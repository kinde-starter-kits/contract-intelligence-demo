# Copy to .env.local and fill in. Never commit real secrets.

# --- Kinde tenant (agent-auth component / token verification) ---
# Your Kinde domain, e.g. https://your-org.kinde.com — issuer of agent M2M tokens.
KINDE_DOMAIN=
# API audience the agent tokens are minted for; required in live mode so a token
# minted for another API in the same tenant cannot be replayed here.
KINDE_AUDIENCE=

# --- Kinde Next.js web app (human sign-in via @kinde-oss/kinde-auth-nextjs) ---
# Web-app (regular) client credentials from the Kinde application.
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
# Kinde issuer URL for the web app, e.g. https://your-org.kinde.com
KINDE_ISSUER_URL=
# Base URL of this app, e.g. http://localhost:3000
KINDE_SITE_URL=http://localhost:3000
# Where Kinde redirects after login / logout.
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# --- Delegation signing ---
# HMAC secret used to sign scope delegations. Must be 32+ chars of high entropy.
DELEGATION_SIGNING_SECRET=

# --- Crew agent M2M application (the AI crew's own Kinde identity) ---
# Machine-to-machine client credentials the agent crew authenticates with.
CREW_M2M_CLIENT_ID=
CREW_M2M_CLIENT_SECRET=

# --- Weaviate (vector store for contract retrieval) ---
# Local Docker: http://localhost:8080 (no API key). Weaviate Cloud: the cluster
# REST endpoint URL + its admin API key. See docs/weaviate-setup.md.
WEAVIATE_URL=
WEAVIATE_API_KEY=

# --- Valyu (external knowledge / search API) ---
VALYU_API_KEY=

# --- Demo authorization mode (SERVER-decided; set on the Convex deployment) ---
# Set with `npx convex env set AUTHZ_MODE broken|intersection` — NOT chosen by
# the calling agent. Default is `broken`.
# broken       = the confused-deputy bug: agent actions authorized on the agent's
#                identity alone; the acting human's permissions are never checked.
# intersection = the fix (phase 6): crew capabilities ∩ the acting human's
#                permissions. Until phase 6, intersection fails closed.
AUTHZ_MODE=broken

# --- Convex ---
# Public deployment URL for the browser client; set by `convex dev`.
NEXT_PUBLIC_CONVEX_URL=
